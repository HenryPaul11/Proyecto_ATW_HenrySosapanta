# ─────────────────────────────────────────────────────────────
#  PowerFit Backend – Variables de entorno (EJEMPLO)
#  Copia este archivo como .env y completa con tus valores reales
#  El archivo .env NO debe subirse a GitHub
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_gimnasio_pg
DB_USERNAME=powerfit_user
DB_PASSWORD=CHANGE_ME

# Servidor
SERVER_PORT=8081

# JWT
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET_MIN_32_CHARS
JWT_EXPIRATION=86400000

# Administrador inicial (se crea automáticamente al iniciar)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=CHANGE_ME
APP_ADMIN_EMAIL=admin@powerfit.com
APP_ADMIN_NOMBRE=Administrador Principal
