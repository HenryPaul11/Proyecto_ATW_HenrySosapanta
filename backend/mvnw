#!/bin/sh
# ----------------------------------------------------------------------------
# Licensed to the Apache Software Foundation (ASF)
# Maven Wrapper startup script - Linux/Mac
# ----------------------------------------------------------------------------

BASE_DIR=$(dirname "$(readlink -f "$0")" 2>/dev/null || dirname "$(realpath "$0")" 2>/dev/null || cd "$(dirname "$0")" && pwd)

MAVEN_PROJECTBASEDIR="$BASE_DIR"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

if [ -r "$WRAPPER_JAR" ]; then
    exec "$JAVA_HOME/bin/java" -cp "$WRAPPER_JAR" "$WRAPPER_LAUNCHER" "$@"
else
    echo "Maven Wrapper jar not found. Please run: mvn -N wrapper:wrapper"
    exit 1
fi
